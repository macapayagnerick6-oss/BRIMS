# Copy this file to .env and fill in your real Twilio and SMTP credentials.

# Twilio SMS
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Email: Resend (recommended for Railway - no SMTP port blocking)
# Get API key at resend.com. Verify a domain for production.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# From address (use verified domain, e.g. BRIMMS <no-reply@yourdomain.com>)
# RESEND_FROM="BRIMMS <onboarding@resend.dev>"  # or your verified domain

# Email: SMTP fallback (when RESEND_API_KEY not set)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# Optional: override default From address
# EMAIL_FROM="Barangay BRIMMS <no-reply@your-domain.com>"

# Optional: override defaults
# PORT=4000
# CORS_ORIGIN: in production set to your frontend origin (e.g. https://brims-2028e.web.app) so email/SMS work.
# CORS_ORIGIN=http://localhost:4200
# Request body size limit in MB (for email with attachments). Default 200. Increase if you get "PayloadTooLargeError" when sending email.
# BODY_LIMIT_MB=200

# Optional: simple shared API token for securing /api/notifications* endpoints.
# When set, clients must send:
#   Authorization: Bearer $API_AUTH_TOKEN
# Leave unset ONLY for local/demo use.
# API_AUTH_TOKEN=your_secure_random_token_here

